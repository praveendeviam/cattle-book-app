<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: backs up Room DB + DataStore prefs to Google Drive -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="cattlebook.db" />
        <include domain="database" path="cattlebook.db-shm" />
        <include domain="database" path="cattlebook.db-wal" />
        <include domain="file" path="datastore/cattlebook_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="cattlebook.db" />
        <include domain="database" path="cattlebook.db-shm" />
        <include domain="database" path="cattlebook.db-wal" />
        <include domain="file" path="datastore/cattlebook_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
